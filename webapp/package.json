{
  "name": "dsff-webapp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder --win --x64"
  },
  "dependencies": {
    "mailparser": "^3.7.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.5.3",
    "vite": "^5.4.1"
  },
  "build": {
    "appId": "com.ds.folderfit",
    "productName": "DS FolderFit",
    "copyright": "Copyright © 2026 DS",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/icon.ico",
      "assets/icon-32.png",
      "assets/icon-256.png"
    ],
    "extraResources": [
      {
        "from": "../dist/dsff.exe",
        "to": "dsff.exe"
      },
      {
        "from": "../src/reference",
        "to": "reference"
      }
    ],
    "directories": {
      "output": "../dist"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
